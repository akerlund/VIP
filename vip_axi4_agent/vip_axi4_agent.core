CAPI=2:
name: "akerlund::vip_axi4_agent:0"
description: "UVM AXI4 verification agent"

filesets:
  tb:
    files:
      # Compilation unit: entry point compiled directly by the simulator
      - vip_axi4_agent.svh
      # Include files: accessed via +incdir+ (included by the .svh or tb packages)
      - vip_axi4_types_pkg.sv: {is_include_file: true}
      - vip_axi4_if.sv: {is_include_file: true}
      - vip_axi4_item_config.sv: {is_include_file: true}
      - vip_axi4_item.sv: {is_include_file: true}
      - vip_axi4_config.sv: {is_include_file: true}
      - vip_axi4_driver_callback.sv: {is_include_file: true}
      - vip_axi4_driver.sv: {is_include_file: true}
      - vip_axi4_monitor_callback.sv: {is_include_file: true}
      - vip_axi4_monitor.sv: {is_include_file: true}
      - vip_axi4_sequencer.sv: {is_include_file: true}
      - vip_axi4_seq_lib.sv: {is_include_file: true}
      - vip_axi4_adapter.sv: {is_include_file: true}
      - vip_axi4_agent_pkg.sv: {is_include_file: true}
      - vip_axi4_agent.sv: {is_include_file: true}
    file_type: systemVerilogSource
    depend:
      - "akerlund::vip_bool:0"

targets:
  default:
    filesets:
      - tb
