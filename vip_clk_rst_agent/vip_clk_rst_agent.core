CAPI=2:
name: "akerlund::vip_clk_rst_agent:0"
description: "UVM clock and reset verification agent"

filesets:
  tb:
    files:
      # Compilation units: compiled directly by the simulator
      - clk_rst_types_pkg.sv
      - clk_rst.svh
      # Include files: accessed via +incdir+ (included by clk_rst.svh)
      - clk_rst_if.sv: {is_include_file: true}
      - clk_rst_item.sv: {is_include_file: true}
      - clk_rst_config.sv: {is_include_file: true}
      - clk_rst_driver.sv: {is_include_file: true}
      - clk_rst_monitor.sv: {is_include_file: true}
      - clk_rst_sequencer.sv: {is_include_file: true}
      - clk_rst_seq_lib.sv: {is_include_file: true}
      - clk_rst_pkg.sv: {is_include_file: true}
      - clk_rst_agent.sv: {is_include_file: true}
    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - tb
